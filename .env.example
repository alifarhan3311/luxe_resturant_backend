PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/luxe_restaurant

# ── JWT / Auth ─────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
# NEVER use a short/guessable secret — minimum 64 random bytes recommended
JWT_SECRET=REPLACE_WITH_128_CHAR_RANDOM_HEX
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separate multiple origins for production: https://yourapp.com,https://www.yourapp.com
CLIENT_URL=http://localhost:5173

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=Luxe Restaurant <no-reply@luxerestaurant.com>

# ── Stripe ─────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── Cloudinary (Image Uploads) ────────────────────────────────────────────────
# Get from: https://console.cloudinary.com → Dashboard
# Required for image uploads on Vercel (diskStorage doesn't work serverless)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

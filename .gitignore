# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.test

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── Seed / Dev-only scripts (local data only — not for production) ────────────
seed.js
seedMenu.js
seedUsers.js
seedGallery.js
migrateToAtlas.js

# ── Uploads (user-generated files — not source code) ─────────────────────────
uploads/*
!uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Runtime / OS artifacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Coverage & test output ────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
tmp/
temp/
.cache/
